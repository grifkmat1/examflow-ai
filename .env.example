# ExamFlow Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=examflow
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=false

# Or use a single connection string (overrides individual settings above)
# DATABASE_URL=postgresql://user:password@host:5432/examflow

# ── Anthropic / Claude AI ────────────────────────────────────
# Get your key at https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Which Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Max tokens for AI responses
CLAUDE_MAX_TOKENS=4096

# ── AI Response Cache ─────────────────────────────────────────
# How long to cache identical AI requests (seconds). 0 = disabled.
AI_CACHE_TTL_SECONDS=300

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
